# ============================================
# E-commerce Backend Environment Variables
# ============================================
# Copy this file to .env and update the values
# The setup script will auto-generate secrets for you
# ============================================

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
API_VERSION=v1
FRONTEND_URL=http://localhost:3000
# Public URL of this API (e.g. https://your-app.onrender.com). Used by Swagger "Try it out" and links.
# APP_URL=https://your-app.onrender.com
# Optional: comma-separated origins allowed for payment redirect URLs (PayU etc.). Default: FRONTEND_URL only.
# ALLOWED_REDIRECT_ORIGINS=https://app.example.com,https://admin.example.com

# ============================================
# Database Configuration
# ============================================
# For Docker Compose (default values)
# These match the docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_db?schema=public

# ============================================
# Social Login (Google, Microsoft)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
MICROSOFT_CLIENT_ID=your_microsoft_client_id
# Optional: MICROSOFT_TENANT_ID (default: common for multi-tenant)
# MICROSOFT_TENANT_ID=common

# ============================================
# JWT Authentication
# ============================================
# These will be auto-generated by the setup script
# For production, use strong, random secrets (64+ characters)
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Redis Cache Configuration
# ============================================
# For Docker Compose (default)
REDIS_URL=redis://localhost:6379

# ============================================
# Admin Account
# ============================================
# Admin user created during database seeding
ADMIN_EMAIL=admin@ecommerce.com
ADMIN_PASSWORD=admin123

# ============================================
# Email / SMTP Configuration
# ============================================
# Used for verification, password reset, order confirmation, and invoice emails.
# If not set, the default SMTP from Admin > Email Services is used (when configured).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@ecommerce.com

# ============================================
# Resend Email Configuration (Optional)
# ============================================
# If set, all transactional emails are sent via Resend (fallback to SMTP if missing).
RESEND_API_KEY=your_resend_api_key
# Address part used as: "MXR Services <RESEND_FROM_EMAIL>"
RESEND_FROM_EMAIL=noreply@mxrservices.in

# ============================================
# Payment Gateways (Optional)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================
# Docker Compose Variables (for local development)
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce_db
POSTGRES_PORT=5432
REDIS_PORT=6379
