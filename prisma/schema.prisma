// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  VENDOR
}

enum AddressType {
  BILLING
  SHIPPING
}

enum OrderStatus {
  CREATED
  PAYMENT_PENDING
  PAID
  PACKED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentGatewayType {
  STRIPE
  PAYU
  PAYPAL
  UPI
  RAZORPAY
  CRYPTO
  BANK_TRANSFER
  COD
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum ShippingMethodType {
  FLAT
  WEIGHT
  DISTANCE
}

enum TaxRuleType {
  PERCENTAGE
  FIXED
}

enum NotificationType {
  ORDER
  PAYMENT
  SHIPPING
  PROMOTION
  SYSTEM
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum SubscriptionInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LoyaltyPointsType {
  EARNED
  REDEEMED
  ADJUSTED
}

enum GiftCardStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum PaymentPlanStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum FraudRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Core Models
model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  password              String
  role                  UserRole  @default(USER)
  firstName             String?
  lastName              String?
  phone                 String?
  emailVerified         Boolean   @default(false)
  verificationToken     String?
  resetPasswordToken    String?
  resetPasswordExpires  DateTime?
  isActive              Boolean   @default(true)
  tenantId              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  addresses             Address[]
  cart                  Cart?
  orders                Order[]
  reviews               Review[]
  wishlist              Wishlist[]
  notifications         Notification[]
  supportTickets        SupportTicket[]
  loyaltyPoints         LoyaltyPoints[]
  wallet                Wallet?
  storeCredits          StoreCredit[]
  subscriptions        Subscription[]
  preOrders             PreOrder[]
  recentlyViewed        RecentlyViewed[]
  savedSearches         SavedSearch[]
  productQuestions      ProductQuestion[]
  waitlist              Waitlist[]
  productAlerts         ProductAlert[]
  stockNotifications    StockNotification[]
  sessions              Session[]
  devices               Device[]
  apiKeys               APIKey[]
  auditLogs             AuditLog[]
  activityLogs         ActivityLog[]
  referrals             Referral[] @relation("Referrer")
  referredBy            Referral[] @relation("Referred")
  giftRegistries        GiftRegistry[]
  tenant                Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([email])
  @@index([tenantId])
}

model Address {
  id        String      @id @default(cuid())
  userId    String
  type      AddressType
  street    String
  city      String
  state     String?
  zipCode   String
  country   String
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  slug        String    @unique
  image       String?
  parentId    String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  tenantId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  translations Translation[] @relation("TranslationCategory")
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([slug])
  @@index([tenantId])
}

model Product {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.Text
  slug              String    @unique
  price             Decimal   @db.Decimal(10, 2)
  compareAtPrice    Decimal?  @db.Decimal(10, 2)
  sku               String?   @unique
  images            String[]  @default([])
  categoryId        String?
  isActive          Boolean   @default(true)
  badges            Json?     @default("[]")
  specifications    Json?
  certifications    Json?     @default("[]")
  warrantyInfo      String?
  lifecycle         String?
  minOrderQuantity  Int       @default(1)
  maxOrderQuantity  Int?
  tenantId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  category          Category? @relation(fields: [categoryId], references: [id])
  variants          ProductVariant[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  reviews           Review[]
  wishlist          Wishlist[]
  inventory         Inventory?
  coupons           Coupon[]  @relation("CouponProducts")
  bundles           ProductBundle[] @relation("BundleProducts")
  recommendations   ProductRecommendation[] @relation("Product")
  recommendedBy     ProductRecommendation[] @relation("Recommended")
  digitalProduct    DigitalProduct?
  subscriptions     Subscription[]
  preOrders         PreOrder[]
  customizations    ProductCustomization[]
  availability      ProductAvailability[]
  recentlyViewed    RecentlyViewed[]
  questions         ProductQuestion[]
  sizeGuides        SizeGuide[]
  videos            ProductVideo[]
  socialProof       SocialProof[]
  waitlist          Waitlist[]
  productAlerts     ProductAlert[]
  stockNotifications StockNotification[]
  translations      Translation[] @relation("TranslationProduct")
  vendorProducts    VendorProduct[]
  warehouseStocks   WarehouseStock[]
  tenant            Tenant?  @relation(fields: [tenantId], references: [id])
  productBadges     ProductBadge[]

  @@index([slug])
  @@index([categoryId])
  @@index([tenantId])
  @@index([isActive])
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  name        String
  sku         String?   @unique
  price       Decimal?  @db.Decimal(10, 2)
  stock       Int       @default(0)
  attributes  Json      // size, color, etc.
  images      String[]  @default([])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  stockNotifications StockNotification[]
  waitlist    Waitlist[]

  @@index([productId])
  @@index([sku])
}

model Cart {
  id        String    @id @default(cuid())
  userId    String    @unique
  version   Int       @default(0)
  tenantId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

model CartItem {
  id          String         @id @default(cuid())
  cartId      String
  productId  String
  variantId  String?
  quantity   Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  cart        Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product     Product        @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([productId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  orderNumber     String      @unique
  status          OrderStatus @default(CREATED)
  total           Decimal     @db.Decimal(10, 2)
  subtotal        Decimal     @db.Decimal(10, 2)
  tax             Decimal     @db.Decimal(10, 2) @default(0)
  shipping        Decimal     @db.Decimal(10, 2) @default(0)
  discount        Decimal     @db.Decimal(10, 2) @default(0)
  currency        String      @default("USD")
  shippingAddress Json
  billingAddress  Json
  ipAddress       String?
  userAgent       String?
  fraudScore      Decimal?    @db.Decimal(5, 2)
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  affiliateId     String?
  tags            Json?       @default("[]")
  version         Int         @default(0)
  tenantId        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  returns         OrderReturn[]
  tracking        OrderTracking[]
  coupons         CouponUsage[]
  notes           OrderNote[]
  splits          OrderSplit[]
  scheduledDelivery ScheduledDelivery?
  paymentPlans     OrderPaymentPlan[]
  invoices        Invoice[]
  creditNotes     CreditNote[]
  giftCardTransactions GiftCardTransaction[]
  stateHistory    OrderStateHistory[]
  tenant          Tenant?     @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([tenantId])
  @@index([createdAt])
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String
  productId  String
  variantId  String?
  quantity   Int
  price      Decimal   @db.Decimal(10, 2)
  total      Decimal   @db.Decimal(10, 2)
  createdAt  DateTime  @default(now())

  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  customizations CustomizationValue[]

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                    String          @id @default(cuid())
  orderId               String
  gateway               PaymentGatewayType
  amount                Decimal         @db.Decimal(10, 2)
  currency              String          @default("USD")
  status                PaymentStatus   @default(PENDING)
  transactionId         String?         @unique
  gatewayTransactionId  String?
  paymentMethod         String?
  metadata              Json?
  version               Int             @default(0)
  tenantId               String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  order                 Order           @relation(fields: [orderId], references: [id])
  transactions         PaymentTransaction[]
  retries               PaymentRetry[]
  chargebacks           Chargeback[]
  tenant                Tenant?         @relation(fields: [tenantId], references: [id])

  @@index([orderId])
  @@index([transactionId])
  @@index([status])
  @@index([tenantId])
}

model PaymentGateway {
  id                  String    @id @default(cuid())
  name                String
  type                PaymentGatewayType @unique
  isActive            Boolean   @default(false)
  config              Json      // API keys, secrets
  webhookSecret       String?
  supportedCurrencies String[]  @default([])
  supportedMethods    String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([type])
  @@index([isActive])
}

model PaymentTransaction {
  id            String          @id @default(cuid())
  paymentId     String
  type          String          // payment/refund
  amount        Decimal         @db.Decimal(10, 2)
  status        PaymentStatus
  gatewayResponse Json?
  createdAt     DateTime        @default(now())

  payment       Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([status])
}

model Review {
  id          String        @id @default(cuid())
  userId      String
  productId   String
  rating      Int           // 1-5
  comment     String?       @db.Text
  status      ReviewStatus  @default(PENDING)
  helpfulCount Int          @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id])
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([status])
}

model Inventory {
  id                String    @id @default(cuid())
  productId         String    @unique
  stock             Int       @default(0)
  reserved          Int       @default(0)
  lowStockThreshold Int       @default(10)
  version           Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements         InventoryMovement[]

  @@index([productId])
}

model InventoryMovement {
  id          String    @id @default(cuid())
  productId   String
  type        String    // in/out/adjustment
  quantity    Int
  reason      String?
  adminId     String?
  createdAt   DateTime  @default(now())

  inventory   Inventory @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
}

model Coupon {
  id            String      @id @default(cuid())
  code          String      @unique
  type          CouponType
  value         Decimal     @db.Decimal(10, 2)
  minPurchase   Decimal?    @db.Decimal(10, 2)
  maxDiscount   Decimal?    @db.Decimal(10, 2)
  usageLimit    Int?
  usedCount     Int         @default(0)
  validFrom     DateTime
  validUntil    DateTime
  isActive      Boolean     @default(true)
  applicableTo  String      @default("all") // all/products/categories
  applicableIds Json?       @default("[]")
  tenantId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  usages        CouponUsage[]
  products      Product[]    @relation("CouponProducts")
  tenant        Tenant?      @relation(fields: [tenantId], references: [id])

  @@index([code])
  @@index([isActive])
  @@index([tenantId])
}

model CouponUsage {
  id            String    @id @default(cuid())
  couponId     String
  userId       String
  orderId      String
  discountAmount Decimal  @db.Decimal(10, 2)
  usedAt       DateTime  @default(now())

  coupon       Coupon    @relation(fields: [couponId], references: [id])
  order        Order     @relation(fields: [orderId], references: [id])

  @@index([couponId])
  @@index([userId])
  @@index([orderId])
}

model Wishlist {
  id        String    @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model ShippingMethod {
  id          String              @id @default(cuid())
  name        String
  type        ShippingMethodType
  isActive    Boolean             @default(true)
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  rates       ShippingRate[]

  @@index([isActive])
}

model ShippingZone {
  id        String    @id @default(cuid())
  name      String
  countries Json      // Array of country codes
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  rates     ShippingRate[]

  @@index([isActive])
}

model ShippingRate {
  id        String    @id @default(cuid())
  zoneId    String
  methodId  String
  minWeight Decimal?  @db.Decimal(10, 2)
  maxWeight Decimal?  @db.Decimal(10, 2)
  minPrice  Decimal?  @db.Decimal(10, 2)
  maxPrice  Decimal?  @db.Decimal(10, 2)
  rate      Decimal   @db.Decimal(10, 2)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  zone      ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  method    ShippingMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@index([methodId])
}

model TaxRule {
  id            String        @id @default(cuid())
  name          String
  rate          Decimal       @db.Decimal(5, 2)
  type          TaxRuleType
  applicableTo  String        @default("all")
  countries     Json?         @default("[]")
  states        Json?         @default("[]")
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([isActive])
}

model OrderReturn {
  id          String        @id @default(cuid())
  orderId     String
  userId      String
  reason      String
  status      ReturnStatus  @default(PENDING)
  items       Json          // Array of items to return
  refundAmount Decimal?     @db.Decimal(10, 2)
  adminNotes  String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order       Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model OrderTracking {
  id              String    @id @default(cuid())
  orderId         String
  carrier         String?
  trackingNumber  String?
  status          String?
  events          Json?     @default("[]")
  estimatedDelivery DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([trackingNumber])
}

model Notification {
  id        String            @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String            @db.Text
  isRead    Boolean           @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationTemplate {
  id        String    @id @default(cuid())
  name      String
  type      NotificationType
  subject   String?
  body      String    @db.Text
  variables Json?     @default("{}")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type])
  @@index([isActive])
}

model EmailTemplate {
  id        String    @id @default(cuid())
  name      String
  type      String    // order-confirmation/shipping/password-reset/etc
  subject   String
  body      String    @db.Text
  variables Json?     @default("{}")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type])
  @@index([isActive])
}

model StockNotification {
  id        String    @id @default(cuid())
  userId    String
  productId String
  variantId String?
  notified  Boolean   @default(false)
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

model Settings {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String    @db.Text
  category    String    // general/shipping/tax/email/notification
  type        String    // string/number/boolean/json
  description String?
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([key])
}

model ActivityLog {
  id          String    @id @default(cuid())
  userId      String?
  adminId     String?
  action      String
  entityType  String
  entityId    String
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model SystemLog {
  id        String    @id @default(cuid())
  level     LogLevel
  message   String    @db.Text
  context   Json?
  createdAt DateTime  @default(now())

  @@index([level])
  @@index([createdAt])
}

model Backup {
  id        String    @id @default(cuid())
  filename  String
  size      BigInt
  type      String
  status    String
  createdAt DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
}

model File {
  id          String    @id @default(cuid())
  filename    String
  originalName String
  path        String
  mimeType    String
  size        BigInt
  uploadedBy  String?
  createdAt   DateTime  @default(now())

  @@index([uploadedBy])
  @@index([createdAt])
}

model AdminPermission {
  id        String    @id @default(cuid())
  adminId   String
  resource  String
  actions   Json      // Array of actions
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([adminId])
  @@index([resource])
}

// Currency and Internationalization
model Currency {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  symbol        String
  exchangeRate  Decimal   @db.Decimal(10, 4) @default(1)
  isActive      Boolean   @default(true)
  isDefault     Boolean   @default(false)
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

model Language {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  isActive  Boolean   @default(true)
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())

  translations Translation[]

  @@index([code])
  @@index([isActive])
}

model Translation {
  id         String   @id @default(cuid())
  entityType String   // product/category/email
  entityId   String
  languageId String
  field      String
  value      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  category   Category? @relation("TranslationCategory", fields: [entityId], references: [id], onDelete: Cascade, map: "Translation_category_entityId_fkey")
  product    Product?  @relation("TranslationProduct", fields: [entityId], references: [id], onDelete: Cascade, map: "Translation_product_entityId_fkey")

  @@unique([entityType, entityId, languageId, field])
  @@index([entityType, entityId])
  @@index([languageId])
}

// Support System
model SupportTicket {
  id          String          @id @default(cuid())
  userId      String
  subject     String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  assignedTo  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id])
  messages    SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
}

model SupportMessage {
  id          String    @id @default(cuid())
  ticketId    String
  userId      String?
  adminId     String?
  message     String    @db.Text
  attachments Json?     @default("[]")
  createdAt   DateTime  @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model FAQ {
  id        String    @id @default(cuid())
  category  String
  question  String    @db.Text
  answer    String    @db.Text
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([category])
  @@index([isActive])
}

// Loyalty & Rewards
model LoyaltyPoints {
  id            String            @id @default(cuid())
  userId        String
  points        Int
