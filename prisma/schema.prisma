}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  authorId    String
  category    String?
  tags        Json?     @default("[]")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@index([authorId])
}

model Banner {
  id        String    @id @default(cuid())
  name      String
  type      String
  imageUrl  String
  link      String?
  position  String
  isActive  Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
  @@index([position])
}

model SEO {
  id          String    @id @default(cuid())
  entityType  String
  entityId    String
  title       String?
  description String?   @db.Text
  keywords    String?
  ogImage     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType, entityId])
}

// Data Consistency & Events
model IdempotencyKey {
  id            String    @id @default(cuid())
  key           String    @unique
  resourceType  String
  resourceId    String?
  response      Json?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([key])
  @@index([expiresAt])
}

model Outbox {
  id          String    @id @default(cuid())
  eventType   String
  payload     Json
  status      String    @default("PENDING")
  retryCount  Int       @default(0)
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
}

model Saga {
  id          String    @id @default(cuid())
  type        String
  state       Json
  currentStep Int
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([type])
}

model DeadLetterQueue {
  id          String    @id @default(cuid())
  eventType   String
  payload     Json
  error       String    @db.Text
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([eventType])
  @@index([createdAt])
}

model EventStore {
  id            String    @id @default(cuid())
  eventId       String    @unique
  eventType     String
  aggregateId   String
  aggregateType String
  payload       Json
  metadata      Json?
  version       Int
  createdAt     DateTime  @default(now())

  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([createdAt])
}

model SearchIndex {
  id            String    @id @default(cuid())
  entityType    String
  entityId      String
  indexedData   Json
  lastIndexedAt DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
}

model ReindexJob {
  id          String    @id @default(cuid())
  type        String
  status      JobStatus @default(PENDING)
  progress    Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  errors      Json?     @default("[]")

  @@index([status])
}

// Multi-tenancy
model Tenant {
  id        String    @id @default(cuid())
  name      String
  domain    String?   @unique
  plan      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users     User[]
  products  Product[]
  orders    Order[]
  payments  Payment[]
  categories Category[]
  carts     Cart[]
  coupons   Coupon[]

  @@index([domain])
  @@index([isActive])
}

// Order State Machine
model OrderStateHistory {
  id        String    @id @default(cuid())
  orderId   String
  fromState String
  toState   String
  reason    String?
  userId    String?
  createdAt DateTime  @default(now())

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

// Fraud & Security
model FraudCheck {
  id          String          @id @default(cuid())
  orderId     String          @unique
  score       Decimal         @db.Decimal(5, 2)
  riskLevel   FraudRiskLevel
  flags       Json?           @default("[]")
  checkedAt   DateTime        @default(now())

  @@index([orderId])
  @@index([riskLevel])
}

model PaymentRetry {
  id            String    @id @default(cuid())
  paymentId     String
  attemptNumber Int
  gatewayUsed   String
  status        String
  errorMessage  String?   @db.Text
  retriedAt     DateTime  @default(now())

  payment       Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([status])
}

model ProductBadge {
  id        String    @id @default(cuid())
  productId String
  badge     String
  startDate DateTime?
  endDate   DateTime?
  priority  Int       @default(0)
  isActive  Boolean   @default(true)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isActive])
}

model GiftRegistry {
  id        String    @id @default(cuid())
  userId    String
  type      String    // wedding/baby/birthday
  title     String
  eventDate DateTime?
  products  Json      // Array of products
  privacy   String    @default("public")
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([slug])
}

model Chargeback {
  id                String    @id @default(cuid())
  paymentId         String
  amount            Decimal   @db.Decimal(10, 2)
  reason            String
  status            String
  evidence          Json?
  responseDeadline  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  payment           Payment   @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([status])
}

model AddressValidation {
  id                String    @id @default(cuid())
  addressId         String    @unique
  isValid           Boolean
  validatedAddress  Json?
  validatedAt       DateTime  @default(now())

  @@index([addressId])
}

// Feature Flags
model FeatureFlag {
  id                String    @id @default(cuid())
  key               String    @unique
  name              String
  description       String?   @db.Text
  category          String?
  isEnabled         Boolean   @default(false)
  rolloutPercentage Int       @default(0)
  enabledFor        Json?     @default("[]")
  disabledFor       Json?     @default("[]")
  startDate         DateTime?
  endDate           DateTime?
  dependencies      Json?     @default("[]")
  conflictsWith     Json?     @default("[]")
  environment       Json?     @default("[]")
  metadata          Json?
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  history           FeatureFlagHistory[]
  rules             FeatureFlagRule[]
  evaluations       FeatureFlagEvaluation[]
  overrides         FeatureFlagOverride[]
  categoryRelation  FeatureCategory? @relation("FeatureFlagCategory", fields: [category], references: [name], onDelete: SetNull)

  @@index([key])
  @@index([isEnabled])
  @@index([category])
}

model FeatureFlagHistory {
  id            String    @id @default(cuid())
  flagId        String
  action        String
  changedBy     String?
  previousValue Json?
  newValue      Json?
  reason        String?
  createdAt     DateTime  @default(now())

  flag          FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)

  @@index([flagId])
  @@index([createdAt])
}

model FeatureFlagRule {
  id          String    @id @default(cuid())
  flagId      String
  type        String
  condition   Json
  priority    Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  flag        FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)

  @@index([flagId])
  @@index([isActive])
}

model FeatureFlagEvaluation {
  id          String    @id @default(cuid())
  flagKey     String
  userId      String?
  tenantId    String?
  result      Boolean
  reason      String?
  metadata    Json?
  evaluatedAt DateTime  @default(now())

  flag        FeatureFlag @relation(fields: [flagKey], references: [key], onDelete: Cascade)

  @@index([flagKey])
  @@index([userId])
  @@index([evaluatedAt])
}

model FeatureFlagOverride {
  id          String    @id @default(cuid())
  flagKey     String
  userId      String?
  tenantId    String?
  isEnabled   Boolean
  expiresAt   DateTime?
  reason      String?
  createdBy   String?
  createdAt   DateTime  @default(now())

  flag        FeatureFlag @relation(fields: [flagKey], references: [key], onDelete: Cascade)

  @@unique([flagKey, userId, tenantId])
  @@index([flagKey])
  @@index([userId])
}

model FeatureCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?   @db.Text
  icon        String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  flags       FeatureFlag[] @relation("FeatureFlagCategory")

  @@index([name])
  @@index([isActive])
}

